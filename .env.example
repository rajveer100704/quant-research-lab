# ============================================================
# AI Quant Trading Research Platform — Environment Template
# Copy this file to .env and fill in your credentials.
# ============================================================

# Binance API Credentials
# Get them from https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading Environment
# Set to 'true' to use Binance Testnet (Highly recommended for research)
BINANCE_TESTNET=true

# Data Storage
# Local directory for market data and OHLCV files
DATA_DIRECTORY=data/

# Logging
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
PLATFORM_LOG_LEVEL=INFO

# Dashboard Settings
# Port for the Streamlit dashboard
DASHBOARD_PORT=8501
