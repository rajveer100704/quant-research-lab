data/
models/
experiments/*
!experiments/run_registry.json
!experiments/__init__.py
!experiments/experiment_manager.py
*.parquet
*.h5
*.keras
*.pt
*.pth

# Environment
.env
*.env.local

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Lock files
uv.lock

# Database
*.db
*.sqlite
*.sqlite3